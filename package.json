{
  "name": "render-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "api:build": "pnpm --filter @render/api build",
    "api:start": "pnpm --filter @render/api start",
    "worker:build": "pnpm --filter @render/worker build",
    "worker:start": "pnpm --filter @render/worker start",
    "worker:lint": "pnpm --filter @render/worker lint",
    "worker:test": "pnpm --filter @render/worker test"
  }
}

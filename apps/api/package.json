{
  "name": "@render/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "prisma generate --schema prisma/schema.prisma && tsc",
    "start": "node dist/main.js",
    "lint": "prisma generate --schema prisma/schema.prisma && tsc --noEmit",
    "test": "export JWT_SECRET=test_secret_32_chars_minimum_value && prisma generate --schema prisma/schema.prisma && vitest run",
    "seed": "prisma db seed --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "6.19.0",
    "@render/queue": "workspace:^",
    "@render/trustlayer-sdk": "workspace:^",
    "fastify": "^5.2.1",
    "fastify-raw-body": "^5.0.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.2",
    "@render/observability": "workspace:*",
    "@render/risk": "workspace:*"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.10",
    "prisma": "6.19.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3",
    "vitest": "^4.1.7"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}

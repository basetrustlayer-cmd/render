generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TrustTier {
  NEW
  BUILDING
  VERIFIED
  TRUSTED
}

enum ListingCategory {
  VEHICLES
  REAL_ESTATE
  ELECTRONICS
  JOBS
  SERVICES
  FASHION
}

enum ListingCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
}

enum ListingStatus {
  PENDING
  LIVE
  MANUAL_REVIEW
  REJECTED
  SOLD
  EXPIRED
}

enum SafeDealStatus {
  INITIATED
  FUNDED
  DELIVERED
  CONFIRMED
  DISPUTED
  REFUNDED
  COMPLETE
}

model User {
  id                String    @id @default(uuid()) @db.Uuid
  trustlayerUserId  String    @unique @map("trustlayer_user_id") @db.VarChar(64)
  email             String?   @unique @db.VarChar(255)
  phone             String?   @db.VarChar(20)
  verificationLevel Int       @default(0) @map("verification_level") @db.SmallInt
  trustScore        Int?      @map("trust_score") @db.SmallInt
  trustTier         TrustTier? @map("trust_tier")
  isBusiness        Boolean   @default(false) @map("is_business")
  isSuspended       Boolean   @default(false) @map("is_suspended")
  whatsappNumber    String?   @map("whatsapp_number") @db.VarChar(20)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  listings          Listing[] @relation("SellerListings")
  purchases         SafeDeal[] @relation("BuyerDeals")
  sales             SafeDeal[] @relation("SellerDeals")
  reviewsGiven      Review[] @relation("ReviewsGiven")
  reviewsReceived   Review[] @relation("ReviewsReceived")

  @@map("users")
}

model Listing {
  id               String            @id @default(uuid()) @db.Uuid
  sellerId         String            @map("seller_id") @db.Uuid
  title            String            @db.VarChar(200)
  description      String?
  price            Decimal           @db.Decimal(12, 2)
  priceNegotiable  Boolean           @default(false) @map("price_negotiable")
  category         ListingCategory
  subcategory      String?           @db.VarChar(100)
  condition        ListingCondition?
  locationRegion   String?           @map("location_region") @db.VarChar(100)
  locationLat      Decimal?          @map("location_lat") @db.Decimal(9, 6)
  locationLng      Decimal?          @map("location_lng") @db.Decimal(9, 6)
  status           ListingStatus     @default(PENDING)
  fraudRiskScore   Decimal?          @map("fraud_risk_score") @db.Decimal(4, 3)
  viewsCount       Int               @default(0) @map("views_count")
  savesCount       Int               @default(0) @map("saves_count")
  expiresAt        DateTime?         @map("expires_at") @db.Timestamptz(6)
  deletedAt        DateTime?         @map("deleted_at") @db.Timestamptz(6)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  seller           User              @relation("SellerListings", fields: [sellerId], references: [id])
  images           ListingImage[]
  safeDeals        SafeDeal[]

  @@index([sellerId])
  @@index([status])
  @@index([category])
  @@index([locationRegion])
  @@map("listings")
}

model SafeDeal {
  id                  String         @id @default(uuid()) @db.Uuid
  listingId           String         @map("listing_id") @db.Uuid
  buyerId             String         @map("buyer_id") @db.Uuid
  sellerId            String         @map("seller_id") @db.Uuid
  amount              Decimal        @db.Decimal(12, 2)
  feeAmount           Decimal        @map("fee_amount") @db.Decimal(12, 2)
  status              SafeDealStatus @default(INITIATED)
  paystackReference   String?        @map("paystack_reference") @db.VarChar(100)
  trustlayerTxnId     String?        @map("trustlayer_txn_id") @db.VarChar(100)
  fundedAt            DateTime?      @map("funded_at") @db.Timestamptz(6)
  deliveredAt         DateTime?      @map("delivered_at") @db.Timestamptz(6)
  confirmedAt         DateTime?      @map("confirmed_at") @db.Timestamptz(6)
  inspectionDeadline  DateTime?      @map("inspection_deadline") @db.Timestamptz(6)
  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  listing             Listing        @relation(fields: [listingId], references: [id])
  buyer               User           @relation("BuyerDeals", fields: [buyerId], references: [id])
  seller              User           @relation("SellerDeals", fields: [sellerId], references: [id])
  review              Review?

  @@index([listingId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@map("safe_deals")
}

model Review {
  id            String   @id @default(uuid()) @db.Uuid
  safeDealId    String   @unique @map("safe_deal_id") @db.Uuid
  reviewerId    String   @map("reviewer_id") @db.Uuid
  revieweeId    String   @map("reviewee_id") @db.Uuid
  rating        Int      @db.SmallInt
  body          String?
  trustlayerRef String?  @map("trustlayer_ref") @db.VarChar(100)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  safeDeal      SafeDeal @relation(fields: [safeDealId], references: [id])
  reviewer      User     @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewee      User     @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  @@index([reviewerId])
  @@index([revieweeId])
  @@map("reviews")
}

model ListingImage {
  id           String   @id @default(uuid()) @db.Uuid
  listingId    String   @map("listing_id") @db.Uuid
  cloudinaryId String   @map("cloudinary_id") @db.VarChar(200)
  url          String
  isCover      Boolean  @default(false) @map("is_cover")
  sortOrder    Int      @default(0) @map("sort_order") @db.SmallInt
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("listing_images")
}

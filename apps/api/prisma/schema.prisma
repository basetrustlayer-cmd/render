generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TrustTier {
  NEW
  BUILDING
  VERIFIED
  TRUSTED
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum ListingCategory {
  VEHICLES
  REAL_ESTATE
  ELECTRONICS
  JOBS
  SERVICES
  FASHION
}

enum ListingCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
}

enum ListingStatus {
  PENDING
  LIVE
  MANUAL_REVIEW
  REJECTED
  SOLD
  EXPIRED
  SUSPENDED
}

enum SafeDealStatus {
  INITIATED
  FUNDED
  DELIVERED
  CONFIRMED
  DISPUTED
  REFUNDED
  COMPLETE
}



enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  NEEDS_BUYER_RESPONSE
  NEEDS_SELLER_RESPONSE
  RESOLVED_BUYER_REFUND
  RESOLVED_SELLER_RELEASE
  CANCELLED
}

enum DisputeEventType {
  OPENED
  EVIDENCE_ADDED
  STATUS_CHANGED
  MODERATOR_NOTE
  RESOLVED
}


enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

model User {
  id                String    @id @default(uuid()) @db.Uuid
  trustlayerUserId  String    @unique @map("trustlayer_user_id") @db.VarChar(64)
  email             String?   @unique @db.VarChar(255)
  phone             String?   @db.VarChar(20)
  verificationLevel        Int       @default(0) @map("verification_level") @db.SmallInt
  verificationStatusCached String?   @map("verification_status_cached") @db.VarChar(50)
  trustScore               Int?      @map("trust_score") @db.SmallInt
  trustTier                TrustTier? @map("trust_tier")
  verificationLastSyncedAt DateTime? @map("verification_last_synced_at")
  verificationProjectionExpiresAt DateTime? @map("verification_projection_expires_at")
  trustBadgeCached         String?   @map("trust_badge_cached") @db.VarChar(100)
  trustLastSyncedAt        DateTime? @map("trust_last_synced_at")
  isBusiness        Boolean   @default(false) @map("is_business")
  isSuspended       Boolean   @default(false) @map("is_suspended")
  role              UserRole  @default(USER)
  suspendedAt       DateTime? @map("suspended_at") @db.Timestamptz(6)
  suspendedReason   String?   @map("suspended_reason")
  moderationNotes   String?   @map("moderation_notes")
  whatsappNumber    String?   @map("whatsapp_number") @db.VarChar(20)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  listings          Listing[] @relation("SellerListings")
  purchases         SafeDeal[] @relation("BuyerDeals")
  sales             SafeDeal[] @relation("SellerDeals")
  reviewsGiven      Review[] @relation("ReviewsGiven")
  reviewsReceived   Review[] @relation("ReviewsReceived")
  authSessions      AuthSession[]
  auditLogs         AuditLog[]
  disputesOpened   Dispute[]
  organizationMemberships OrganizationMember[]
  conversationsAsBuyer Conversation[] @relation("BuyerConversations")
  conversationsAsSeller Conversation[] @relation("SellerConversations")
  messagesSent Message[] @relation("SentMessages")
  notificationPreference NotificationPreference?

  @@map("users")
}


model AuthSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  jti              String    @unique @db.VarChar(100)
  refreshTokenHash String    @unique @map("refresh_token_hash") @db.VarChar(128)
  deviceFingerprintHash String? @map("device_fingerprint_hash") @db.VarChar(128)
  csrfTokenHash    String?   @map("csrf_token_hash") @db.VarChar(128)
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address") @db.VarChar(64)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jti])
  @@index([expiresAt])
  @@index([deviceFingerprintHash])
  @@map("auth_sessions")
}

model Listing {
  id               String            @id @default(uuid()) @db.Uuid
  sellerId         String            @map("seller_id") @db.Uuid
  organizationId   String?           @map("organization_id") @db.Uuid
  title            String            @db.VarChar(200)
  description      String?
  price            Decimal           @db.Decimal(12, 2)
  priceNegotiable  Boolean           @default(false) @map("price_negotiable")
  category         ListingCategory
  subcategory      String?           @db.VarChar(100)
  condition        ListingCondition?
  locationRegion   String?           @map("location_region") @db.VarChar(100)
  locationLat      Decimal?          @map("location_lat") @db.Decimal(9, 6)
  locationLng      Decimal?          @map("location_lng") @db.Decimal(9, 6)
  status           ListingStatus     @default(PENDING)
  fraudRiskScore   Decimal?          @map("fraud_risk_score") @db.Decimal(4, 3)
  viewsCount       Int               @default(0) @map("views_count")
  savesCount       Int               @default(0) @map("saves_count")
  expiresAt        DateTime?         @map("expires_at") @db.Timestamptz(6)
  deletedAt        DateTime?         @map("deleted_at") @db.Timestamptz(6)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  seller           User              @relation("SellerListings", fields: [sellerId], references: [id])
  organization     Organization?      @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  images           ListingImage[]
  safeDeals        SafeDeal[]
  conversations    Conversation[]

  @@index([sellerId])
  @@index([organizationId])
  @@index([status])
  @@index([category])
  @@index([locationRegion])
  @@map("listings")
}

model SafeDeal {
  id                  String         @id @default(uuid()) @db.Uuid
  listingId           String         @map("listing_id") @db.Uuid
  buyerId             String         @map("buyer_id") @db.Uuid
  sellerId            String         @map("seller_id") @db.Uuid
  organizationId      String?        @map("organization_id") @db.Uuid
  amount              Decimal        @db.Decimal(12, 2)
  feeAmount           Decimal        @map("fee_amount") @db.Decimal(12, 2)
  status              SafeDealStatus @default(INITIATED)
  trustLayerEscrowId  String?        @map("trustlayer_escrow_id") @db.VarChar(100)
  checkoutUrl         String?        @map("checkout_url")
  escrowStatusCached String?        @map("escrow_status_cached") @db.VarChar(40)
  escrowLastSyncedAt DateTime?      @map("escrow_last_synced_at") @db.Timestamptz(6)
  fundedAt            DateTime?      @map("funded_at") @db.Timestamptz(6)
  deliveredAt         DateTime?      @map("delivered_at") @db.Timestamptz(6)
  confirmedAt         DateTime?      @map("confirmed_at") @db.Timestamptz(6)
  inspectionDeadline  DateTime?      @map("inspection_deadline") @db.Timestamptz(6)
  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  listing             Listing        @relation(fields: [listingId], references: [id])
  buyer               User           @relation("BuyerDeals", fields: [buyerId], references: [id])
  seller              User           @relation("SellerDeals", fields: [sellerId], references: [id])
  organization        Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  review              Review?
  dispute             Dispute?

  @@index([listingId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([organizationId])
  @@index([status])
  @@map("safe_deals")
}



model Review {
  id            String   @id @default(uuid()) @db.Uuid
  safeDealId    String   @unique @map("safe_deal_id") @db.Uuid
  reviewerId    String   @map("reviewer_id") @db.Uuid
  revieweeId    String   @map("reviewee_id") @db.Uuid
  rating        Int      @db.SmallInt
  body          String?
  trustlayerRef String?  @map("trustlayer_ref") @db.VarChar(100)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  safeDeal      SafeDeal @relation(fields: [safeDealId], references: [id])
  reviewer      User     @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewee      User     @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  @@index([reviewerId])
  @@index([revieweeId])
  @@map("reviews")
}

model ListingImage {
  id           String   @id @default(uuid()) @db.Uuid
  listingId    String   @map("listing_id") @db.Uuid
  cloudinaryId String   @map("cloudinary_id") @db.VarChar(200)
  url          String
  isCover      Boolean  @default(false) @map("is_cover")
  sortOrder    Int      @default(0) @map("sort_order") @db.SmallInt
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("listing_images")
}


model Conversation {
  id             String    @id @default(uuid()) @db.Uuid
  buyerId        String    @map("buyer_id") @db.Uuid
  sellerId       String    @map("seller_id") @db.Uuid
  listingId      String?   @map("listing_id") @db.Uuid
  organizationId String?   @map("organization_id") @db.Uuid
  lastMessageAt  DateTime? @map("last_message_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  buyer          User      @relation("BuyerConversations", fields: [buyerId], references: [id], onDelete: Cascade)
  seller         User      @relation("SellerConversations", fields: [sellerId], references: [id], onDelete: Cascade)
  listing        Listing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  messages       Message[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([listingId])
  @@index([organizationId])
  @@index([lastMessageAt])
  @@unique([buyerId, sellerId, listingId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  senderId       String       @map("sender_id") @db.Uuid
  body           String       @db.VarChar(2000)
  readAt         DateTime?    @map("read_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}


model NotificationPreference {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @unique @map("user_id") @db.Uuid
  email         Boolean  @default(true)
  sms           Boolean  @default(true)
  push          Boolean  @default(false)
  marketing     Boolean  @default(false)
  transactional Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notification_preferences")
}

model OtpChallenge {
  id          String    @id @default(uuid()) @db.Uuid
  phone       String    @db.VarChar(20)
  codeHash    String    @map("code_hash") @db.VarChar(64)
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt  DateTime? @map("consumed_at") @db.Timestamptz(6)
  attempts    Int       @default(0) @db.SmallInt
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([phone])
  @@index([expiresAt])
  @@map("otp_challenges")
}


model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  organizationId String? @map("organization_id") @db.Uuid
  action      String   @db.VarChar(120)
  entityType  String?  @map("entity_type") @db.VarChar(80)
  entityId    String?  @map("entity_id") @db.VarChar(120)
  requestId   String?  @map("request_id") @db.VarChar(120)
  correlationId String? @map("correlation_id") @db.VarChar(120)
  source      String?  @db.VarChar(80)
  ipAddress   String?  @map("ip_address") @db.VarChar(64)
  userAgent   String?  @map("user_agent")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([organizationId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([requestId])
  @@index([correlationId])
  @@index([source])
  @@index([createdAt])
  @@map("audit_logs")
}

model WebhookEvent {
  id            String    @id @default(uuid()) @db.Uuid
  provider      String    @db.VarChar(40)
  eventId       String    @map("event_id") @db.VarChar(160)
  eventType     String    @map("event_type") @db.VarChar(120)
  status        String    @default("RECEIVED") @db.VarChar(40)
  processedAt   DateTime? @map("processed_at") @db.Timestamptz(6)
  payload       Json?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([provider, eventId])
  @@index([provider])
  @@index([eventType])
  @@index([status])
  @@index([createdAt])
  @@map("webhook_events")
}


model Dispute {
  id          String        @id @default(uuid()) @db.Uuid
  safeDealId  String        @unique @map("safe_deal_id") @db.Uuid
  organizationId String?      @map("organization_id") @db.Uuid
  openedById String        @map("opened_by_id") @db.Uuid
  status      DisputeStatus @default(OPEN)
  reason      String        @db.VarChar(500)
  resolution  String?
  resolvedAt  DateTime?     @map("resolved_at") @db.Timestamptz(6)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  safeDeal    SafeDeal      @relation(fields: [safeDealId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  openedBy    User          @relation(fields: [openedById], references: [id])
  events      DisputeEvent[]

  @@index([status])
  @@index([organizationId])
  @@index([openedById])
  @@index([createdAt])
  @@map("disputes")
}

model DisputeEvent {
  id          String           @id @default(uuid()) @db.Uuid
  disputeId   String           @map("dispute_id") @db.Uuid
  actorUserId String?          @map("actor_user_id") @db.Uuid
  eventType   DisputeEventType @map("event_type")
  note        String?
  metadata    Json?
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  dispute     Dispute          @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
  @@index([actorUserId])
  @@index([eventType])
  @@index([createdAt])
  @@map("dispute_events")
}


model Organization {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String             @db.VarChar(200)
  slug               String             @unique @db.VarChar(120)
  trustlayerTenantId String?            @unique @map("trustlayer_tenant_id") @db.VarChar(100)
  status             OrganizationStatus @default(ACTIVE)
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  members            OrganizationMember[]
  listings           Listing[]
  safeDeals          SafeDeal[]
  disputes           Dispute[]
  auditLogs          AuditLog[]
  conversations      Conversation[]

  @@index([status])
  @@map("organizations")
}

model OrganizationMember {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
  @@map("organization_members")
}

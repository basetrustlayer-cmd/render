generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TrustTier {
  NEW
  BUILDING
  VERIFIED
  TRUSTED
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum ListingCategory {
  VEHICLES
  REAL_ESTATE
  ELECTRONICS
  JOBS
  SERVICES
  FASHION
}

enum ListingCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
}

enum ListingStatus {
  PENDING
  LIVE
  MANUAL_REVIEW
  REJECTED
  SOLD
  EXPIRED
  SUSPENDED
}

enum SafeDealStatus {
  INITIATED
  FUNDED
  DELIVERED
  CONFIRMED
  DISPUTED
  REFUNDED
  COMPLETE
}

enum EscrowLedgerEntryType {
  BUYER_HOLD
  PLATFORM_FEE
  SELLER_PAYABLE
  BUYER_REFUND
  SETTLEMENT_RELEASE
  ADJUSTMENT
}

enum SettlementStatus {
  PENDING
  READY
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

model User {
  id                String    @id @default(uuid()) @db.Uuid
  trustlayerUserId  String    @unique @map("trustlayer_user_id") @db.VarChar(64)
  email             String?   @unique @db.VarChar(255)
  phone             String?   @db.VarChar(20)
  verificationLevel Int       @default(0) @map("verification_level") @db.SmallInt
  trustScore        Int?      @map("trust_score") @db.SmallInt
  trustTier         TrustTier? @map("trust_tier")
  isBusiness        Boolean   @default(false) @map("is_business")
  isSuspended       Boolean   @default(false) @map("is_suspended")
  role              UserRole  @default(USER)
  suspendedAt       DateTime? @map("suspended_at") @db.Timestamptz(6)
  suspendedReason   String?   @map("suspended_reason")
  moderationNotes   String?   @map("moderation_notes")
  whatsappNumber    String?   @map("whatsapp_number") @db.VarChar(20)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  listings          Listing[] @relation("SellerListings")
  purchases         SafeDeal[] @relation("BuyerDeals")
  sales             SafeDeal[] @relation("SellerDeals")
  reviewsGiven      Review[] @relation("ReviewsGiven")
  reviewsReceived   Review[] @relation("ReviewsReceived")
  authSessions      AuthSession[]
  auditLogs         AuditLog[]
  settlements       Settlement[]

  @@map("users")
}


model AuthSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  jti              String    @unique @db.VarChar(100)
  refreshTokenHash String    @unique @map("refresh_token_hash") @db.VarChar(128)
  deviceFingerprintHash String? @map("device_fingerprint_hash") @db.VarChar(128)
  csrfTokenHash    String?   @map("csrf_token_hash") @db.VarChar(128)
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address") @db.VarChar(64)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jti])
  @@index([expiresAt])
  @@index([deviceFingerprintHash])
  @@map("auth_sessions")
}

model Listing {
  id               String            @id @default(uuid()) @db.Uuid
  sellerId         String            @map("seller_id") @db.Uuid
  title            String            @db.VarChar(200)
  description      String?
  price            Decimal           @db.Decimal(12, 2)
  priceNegotiable  Boolean           @default(false) @map("price_negotiable")
  category         ListingCategory
  subcategory      String?           @db.VarChar(100)
  condition        ListingCondition?
  locationRegion   String?           @map("location_region") @db.VarChar(100)
  locationLat      Decimal?          @map("location_lat") @db.Decimal(9, 6)
  locationLng      Decimal?          @map("location_lng") @db.Decimal(9, 6)
  status           ListingStatus     @default(PENDING)
  fraudRiskScore   Decimal?          @map("fraud_risk_score") @db.Decimal(4, 3)
  viewsCount       Int               @default(0) @map("views_count")
  savesCount       Int               @default(0) @map("saves_count")
  expiresAt        DateTime?         @map("expires_at") @db.Timestamptz(6)
  deletedAt        DateTime?         @map("deleted_at") @db.Timestamptz(6)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  seller           User              @relation("SellerListings", fields: [sellerId], references: [id])
  images           ListingImage[]
  safeDeals        SafeDeal[]

  @@index([sellerId])
  @@index([status])
  @@index([category])
  @@index([locationRegion])
  @@map("listings")
}

model SafeDeal {
  id                  String         @id @default(uuid()) @db.Uuid
  listingId           String         @map("listing_id") @db.Uuid
  buyerId             String         @map("buyer_id") @db.Uuid
  sellerId            String         @map("seller_id") @db.Uuid
  amount              Decimal        @db.Decimal(12, 2)
  feeAmount           Decimal        @map("fee_amount") @db.Decimal(12, 2)
  status              SafeDealStatus @default(INITIATED)
  trustLayerEscrowId  String?        @map("trustlayer_escrow_id") @db.VarChar(100)
  checkoutUrl         String?        @map("checkout_url")
  escrowStatusCached String?        @map("escrow_status_cached") @db.VarChar(40)
  escrowLastSyncedAt DateTime?      @map("escrow_last_synced_at") @db.Timestamptz(6)
  fundedAt            DateTime?      @map("funded_at") @db.Timestamptz(6)
  deliveredAt         DateTime?      @map("delivered_at") @db.Timestamptz(6)
  confirmedAt         DateTime?      @map("confirmed_at") @db.Timestamptz(6)
  inspectionDeadline  DateTime?      @map("inspection_deadline") @db.Timestamptz(6)
  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  listing             Listing        @relation(fields: [listingId], references: [id])
  buyer               User           @relation("BuyerDeals", fields: [buyerId], references: [id])
  seller              User           @relation("SellerDeals", fields: [sellerId], references: [id])
  review              Review?
  ledgerEntries       EscrowLedgerEntry[]
  settlement          Settlement?

  @@index([listingId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@map("safe_deals")
}

model EscrowLedgerEntry {
  id             String                @id @default(uuid()) @db.Uuid
  safeDealId     String                @map("safe_deal_id") @db.Uuid
  entryType      EscrowLedgerEntryType @map("entry_type")
  amount         Decimal               @db.Decimal(12, 2)
  currency       String                @default("GHS") @db.VarChar(3)
  idempotencyKey String                @unique @map("idempotency_key") @db.VarChar(160)
  metadata       Json?
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  safeDeal       SafeDeal              @relation(fields: [safeDealId], references: [id], onDelete: Cascade)

  @@index([safeDealId])
  @@index([entryType])
  @@index([createdAt])
  @@map("escrow_ledger_entries")
}

model Settlement {
  id                    String           @id @default(uuid()) @db.Uuid
  safeDealId            String           @unique @map("safe_deal_id") @db.Uuid
  sellerId              String           @map("seller_id") @db.Uuid
  grossAmount           Decimal          @map("gross_amount") @db.Decimal(12, 2)
  platformFeeAmount     Decimal          @map("platform_fee_amount") @db.Decimal(12, 2)
  sellerReceivableAmount Decimal         @map("seller_receivable_amount") @db.Decimal(12, 2)
  currency              String           @default("GHS") @db.VarChar(3)
  status                SettlementStatus @default(PENDING)
  provider              String?          @db.VarChar(40)
  providerReference     String?          @map("provider_reference") @db.VarChar(120)
  failureReason         String?          @map("failure_reason")
  readyAt               DateTime?        @map("ready_at") @db.Timestamptz(6)
  paidAt                DateTime?        @map("paid_at") @db.Timestamptz(6)
  createdAt             DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  safeDeal              SafeDeal         @relation(fields: [safeDealId], references: [id], onDelete: Cascade)
  seller                User             @relation(fields: [sellerId], references: [id])

  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
  @@map("settlements")
}

model Review {
  id            String   @id @default(uuid()) @db.Uuid
  safeDealId    String   @unique @map("safe_deal_id") @db.Uuid
  reviewerId    String   @map("reviewer_id") @db.Uuid
  revieweeId    String   @map("reviewee_id") @db.Uuid
  rating        Int      @db.SmallInt
  body          String?
  trustlayerRef String?  @map("trustlayer_ref") @db.VarChar(100)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  safeDeal      SafeDeal @relation(fields: [safeDealId], references: [id])
  reviewer      User     @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewee      User     @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  @@index([reviewerId])
  @@index([revieweeId])
  @@map("reviews")
}

model ListingImage {
  id           String   @id @default(uuid()) @db.Uuid
  listingId    String   @map("listing_id") @db.Uuid
  cloudinaryId String   @map("cloudinary_id") @db.VarChar(200)
  url          String
  isCover      Boolean  @default(false) @map("is_cover")
  sortOrder    Int      @default(0) @map("sort_order") @db.SmallInt
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("listing_images")
}

model OtpChallenge {
  id          String    @id @default(uuid()) @db.Uuid
  phone       String    @db.VarChar(20)
  codeHash    String    @map("code_hash") @db.VarChar(64)
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt  DateTime? @map("consumed_at") @db.Timestamptz(6)
  attempts    Int       @default(0) @db.SmallInt
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([phone])
  @@index([expiresAt])
  @@map("otp_challenges")
}


model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String   @db.VarChar(120)
  entityType  String?  @map("entity_type") @db.VarChar(80)
  entityId    String?  @map("entity_id") @db.VarChar(120)
  ipAddress   String?  @map("ip_address") @db.VarChar(64)
  userAgent   String?  @map("user_agent")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

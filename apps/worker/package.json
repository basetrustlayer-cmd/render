{
  "name": "@render/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "prisma generate --schema ../api/prisma/schema.prisma && tsc",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
    "lint": "prisma generate --schema ../api/prisma/schema.prisma && tsc --noEmit",
    "test": "prisma generate --schema ../api/prisma/schema.prisma && tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "6.19.0",
    "@render/queue": "workspace:*",
    "@render/trustlayer-sdk": "workspace:^",
    "bullmq": "^5.64.1",
    "ioredis": "^5.8.2",
    "@render/observability": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "prisma": "6.19.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  }
}
